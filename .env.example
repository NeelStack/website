# ─── Site URL ──────────────────────────────────────────────────────────────────
# Used by lib/site-url.ts for canonical URLs and metadata
NEXT_PUBLIC_SITE_URL=https://neelstack.com

# ─── Resend (Email API) ─────────────────────────────────────────────────────────
# Get your key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Contact Form Routing ───────────────────────────────────────────────────────
# Where contact/quote form submissions land
CONTACT_RECEIVER_EMAIL=contact@neelstack.com

# Must be a verified Resend sender domain (e.g. no-reply@neelstack.com)
CONTACT_SENDER_EMAIL=NeelStack Portal <no-reply@neelstack.com>
